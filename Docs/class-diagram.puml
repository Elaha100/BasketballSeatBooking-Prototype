@startuml
title Basketball Seat Booking - Class Diagram

enum SeatStatus {
  AVAILABLE
  SELECTED
  BOOKED
}

class Team {
  +name: String
  +themeColor: String
}

class Match {
  +matchId: String
  +dateTime: String
  +arena: String
}

class Seat {
  +seatId: String
  +side: String
  +status: SeatStatus
}

class User {
  +name: String
  +email: String
}

class Booking {
  +bookingId: String
  +createdAt: String
}

Match "1" -- "2" Team : plays
Match "1" o-- "*" Seat : contains

User "1" -- "*" Booking : creates
Booking "*" -- "1" Match : for
Booking "1" -- "*" Seat : includes

@enduml